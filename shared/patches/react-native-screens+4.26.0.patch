 - (void)viewDidLayoutSubviews
 {
   [super viewDidLayoutSubviews];
+  // Keybase patch: a screen marked with this backTitle hosts an intentionally empty,
+  // transparent navigation bar. It is kept visible so pushes get the coordinated bar-content
+  // transition — unhiding a hidden bar mid-push makes iOS 26 slide the whole UINavigationBar
+  // in from the right as its own animated plane, desynced from the screen slide (see
+  // react-native-screens issue #3773). Cancel the bar's safe-area contribution so nested
+  // content (e.g. a nested stack's own header) doesn't shift down by the bar height.
+  RNSScreenStackHeaderConfig *emptyBarCfg = [self.screenView findHeaderConfig];
+  if ([emptyBarCfg.backTitle isEqualToString:@"RNS_EMPTY_BAR"]) {
+    CGFloat emptyBarHeight = self.navigationController.navigationBar.frame.size.height;
+    if (emptyBarHeight > 0 && self.additionalSafeAreaInsets.top != -emptyBarHeight) {
+      UIEdgeInsets insets = self.additionalSafeAreaInsets;
+      insets.top = -emptyBarHeight;
+      self.additionalSafeAreaInsets = insets;
+    }
+  }
 
